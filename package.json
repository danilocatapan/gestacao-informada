{
  "name": "gestacao-informada",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "astro check",
    "check": "astro check",
    "test:content": "node scripts/test-content.mjs && node scripts/test-editorial-validation.mjs && node scripts/test-publication-search.mjs && node scripts/test-editorial-pipeline.mjs",
    "test:build": "node scripts/test-build.mjs",
    "test:e2e": "playwright test",
    "test:e2e:editorial": "playwright test --config=playwright.editorial.config.ts",
    "editorial:review": "node scripts/run-editorial-pipeline.mjs review",
    "editorial:review:mvp": "node scripts/run-editorial-pipeline.mjs review-mvp",
    "editorial:review:all": "node scripts/run-editorial-pipeline.mjs review-all",
    "editorial:mark-draft": "node scripts/run-editorial-pipeline.mjs mark-draft",
    "editorial:panel": "node scripts/editorial-review-server.mjs",
    "editorial:references:sync": "node scripts/sync-reference-database.mjs",
    "test": "npm run lint && npm run test:content && npm run build && npm run test:build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/poppins": "^5.2.7",
    "astro": "^6.4.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@playwright/test": "^1.60.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run test:content"
  }
}
