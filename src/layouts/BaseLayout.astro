---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Seo from '../components/Seo.astro';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  additionalStructuredData?: Record<string, unknown>[];
}

const { title, description, path = '', additionalStructuredData = [] } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Seo title={title} description={description} path={path} additionalStructuredData={additionalStructuredData} />
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <Header />
    <main id="conteudo"><slot /></main>
    <Footer />
  </body>
</html>
