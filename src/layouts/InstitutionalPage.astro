---
import ContentNotice, { type NoticeKind } from '../components/ContentNotice.astro';
import NextSteps, { type NextStep } from '../components/NextSteps.astro';
import PrintAction from '../components/PrintAction.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  path: string;
  showNotice?: boolean;
  noticeKind?: NoticeKind;
  nextSteps?: NextStep[];
  printable?: boolean;
}

const {
  title,
  description,
  eyebrow,
  path,
  showNotice = true,
  noticeKind = 'clinical',
  nextSteps = [],
  printable = false,
} = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
  <section class="page-hero">
    <div class="container narrow">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
    </div>
  </section>
  <section class="content-section">
    <div class:list={['container', 'article-grid', { 'article-grid-single': !showNotice }]}>
      {showNotice && <ContentNotice kind={noticeKind} />}
      <article class="prose">
        {printable && <PrintAction />}
        <slot />
        {nextSteps.length > 0 && <NextSteps steps={nextSteps} />}
      </article>
    </div>
  </section>
</BaseLayout>
