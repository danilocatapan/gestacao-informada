---
import { getEntry, render } from 'astro:content';
import ImmediateSupport from '../components/ImmediateSupport.astro';
import InstitutionalPage from '../layouts/InstitutionalPage.astro';
const page = await getEntry('pages', 'acolhimento-e-luto');
if (!page) throw new Error('Página institucional não encontrada.');
const { Content } = await render(page);
---
<InstitutionalPage
  {...page.data}
  path="acolhimento-e-luto/"
  showNotice={false}
  nextSteps={[
    { label: 'Organizar uma conversa importante', href: 'materiais/', primary: true },
    { label: 'Ler sobre perda gestacional', href: 'artigos/entendendo-a-perda-gestacional/' },
  ]}
>
  <ImmediateSupport slot="before-content" />
  <Content />
</InstitutionalPage>
