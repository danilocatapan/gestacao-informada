---
import { getCollection, getEntry, render } from 'astro:content';
import ArticleCollection from '../components/ArticleCollection.astro';
import InstitutionalPage from '../layouts/InstitutionalPage.astro';
const page = await getEntry('pages', 'trombofilias-e-investigacao');
if (!page) throw new Error('Página institucional não encontrada.');
const { Content } = await render(page);
const articles = (await getCollection('articles', ({ data }) =>
  data.status === 'approved' && data.journeys.includes('recurrent-loss')));
---
<InstitutionalPage
  {...page.data}
  path="trombofilias-e-investigacao/"
  showNotice={false}
  nextSteps={[
    { label: 'Preparar uma conversa com profissionais', href: 'materiais/', primary: true },
    { label: 'Ver todos os artigos', href: 'artigos/' },
  ]}
>
  <Content />
  <ArticleCollection
    slot="related"
    articles={articles}
    id="leituras-sobre-investigacao"
    title="Investigar sem transformar possibilidades em certezas"
    description="Leituras sobre perdas recorrentes, trombofilias, síndrome antifosfolípide e MTHFR."
  />
</InstitutionalPage>
