---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { canPublishGlossary } from '../../lib/publication';
import { withBaseUrl, withCanonicalUrl } from '../../lib/urls';

export async function getStaticPaths() {
  const approvedArticles = await getCollection('articles', ({ data }) => data.status === 'approved');
  return approvedArticles.map((article) => ({ params: { id: article.id }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const author = article.data.authoredBy ? await getEntry(article.data.authoredBy) : undefined;
const approvedArticles = await getCollection('articles', ({ data }) => data.status === 'approved');
const approvedGlossary = await getCollection('glossary', ({ data }) => data.status === 'approved');
const glossaryTerms = canPublishGlossary(approvedArticles.length, approvedGlossary.length)
  ? (await Promise.all(article.data.glossaryTerms.map((reference) => getEntry(reference))))
    .filter((entry) => entry?.data.status === 'approved')
  : [];
const target = `articles/${article.id}`;
const records = await getCollection('editorialRecords', ({ data }) => data.target === target);
const domainApprovals = records
  .filter(({ data }) => data.event === 'domain_review' && data.decision === 'approved')
  .sort((left, right) => right.data.occurredAt.getTime() - left.data.occurredAt.getTime());
const latestApprovals = domainApprovals.filter((record, index, all) =>
  all.findIndex((candidate) => candidate.data.domain === record.data.domain) === index);
const reviewers = await Promise.all(latestApprovals.map(async ({ data }) => ({
  domain: data.domain,
  occurredAt: data.occurredAt,
  contributor: await getEntry(data.actor),
})));
const articlePath = `artigos/${article.id}/`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': ['Article', 'MedicalWebPage'],
    headline: article.data.title,
    description: article.data.description,
    url: withCanonicalUrl(articlePath),
    dateModified: article.data.lastUpdatedAt.toISOString(),
    author: author ? { '@type': 'Organization', name: author.data.name } : undefined,
    reviewedBy: reviewers
      .filter(({ contributor }) => contributor)
      .map(({ contributor }) => ({ '@type': 'Person', name: contributor?.data.name })),
  },
];
---
<BaseLayout title={article.data.title} description={article.data.description} path={articlePath} additionalStructuredData={structuredData}>
  <section class="page-hero"><div class="container narrow"><span class="eyebrow">{article.data.category}</span><h1>{article.data.title}</h1><p class="lead">{article.data.description}</p></div></section>
  <section class="content-section">
    <div class="container article-grid">
      <article class="prose"><Content /></article>
      <aside class="article-meta">
        <h2>Sobre este conteúdo</h2>
        {author && <p><strong>Autoria:</strong> {author.data.name}<br />{author.data.credentials}</p>}
        {reviewers.map(({ domain, occurredAt, contributor }) => contributor && (
          <p><strong>Revisão {domain}:</strong> {contributor.data.name}<br />{contributor.data.credentials}<br />{occurredAt.toLocaleDateString('pt-BR')}</p>
        ))}
        <p><strong>Última atualização:</strong> {article.data.lastUpdatedAt.toLocaleDateString('pt-BR')}</p>
        <p>{article.data.medicalDisclaimer}</p>
        {glossaryTerms.length > 0 && (
          <>
            <h3>Termos relacionados</h3>
            <ul data-article-glossary-links>{glossaryTerms.map((entry) => entry && <li><a href={withBaseUrl(`glossario/${entry.data.slug}/`)}>{entry.data.term}</a></li>)}</ul>
          </>
        )}
        <h3>Assistência por IA</h3>
        <p data-ai-disclosure>{article.data.aiAssistance.disclosure}</p>
        <h3>Fontes</h3>
        <ul>{article.data.sources.map((source) => <li><a href={source.url}>{source.title}</a> — {source.publisher}</li>)}</ul>
        {article.data.inspirationCredits.length > 0 && (
          <>
            <h3>Créditos de inspiração editorial</h3>
            <p>Estes materiais ajudaram a identificar dúvidas e pautas. Não são fontes clínicas, revisores ou endosso ao conteúdo.</p>
            <ul data-inspiration-credits>{article.data.inspirationCredits.map((credit) => <li><a href={credit.url}>{credit.name}</a> — {credit.purpose}</li>)}</ul>
          </>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
