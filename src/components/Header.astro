---
import { site } from '../lib/site';
import { withBaseUrl } from '../lib/urls';

interface Props {
  path?: string;
}

const { path = '' } = Astro.props;
const isCurrent = (linkPath: string) => path === linkPath || path.startsWith(linkPath);
const links = [
  ['Entender', 'entender-a-perda/'],
  ['Acolhimento', 'acolhimento-e-luto/'],
  ['Organizar', 'materiais/'],
  ['Buscar', 'busca/'],
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBaseUrl()} aria-label={`${site.name}, página inicial`}>
      <img src={withBaseUrl('brand/symbol.png')} width="56" height="56" alt="" />
      <span><strong>Gestação</strong><small>Informada</small></span>
    </a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation">
      <span>Menu</span>
      <span class="menu-toggle-icon" aria-hidden="true"></span>
    </button>
    <nav id="primary-navigation" aria-label="Navegação principal">
      <ul>
        {links.map(([label, linkPath]) => (
          <li><a href={withBaseUrl(linkPath)} aria-current={isCurrent(linkPath) ? 'page' : undefined}>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const navigation = document.querySelector<HTMLElement>('#primary-navigation');
  header?.setAttribute('data-menu-ready', '');

  const closeMenu = () => {
    toggle?.setAttribute('aria-expanded', 'false');
    navigation?.removeAttribute('data-open');
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') !== 'true';
    toggle.setAttribute('aria-expanded', String(open));
    navigation?.toggleAttribute('data-open', open);
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
      toggle?.focus();
    }
  });
</script>
