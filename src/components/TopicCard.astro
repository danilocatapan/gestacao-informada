---
import { withBaseUrl } from '../lib/urls';
import Icon, { type IconName } from './Icon.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: IconName;
  status?: string;
  linkLabel?: string;
}

const { title, description, href, icon, status, linkLabel = 'Acessar' } = Astro.props;
---

<a class="topic-card" href={withBaseUrl(href)}>
  <span class="topic-icon"><Icon name={icon} /></span>
  {status && <span class="topic-status">{status}</span>}
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="card-link">{linkLabel} <span aria-hidden="true">→</span></span>
</a>
