---
import { withBaseUrl } from '../lib/urls';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a class="topic-card" href={withBaseUrl(href)}>
  <span class="topic-icon" aria-hidden="true">{icon}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="card-link">Conhecer esta área <span aria-hidden="true">→</span></span>
</a>
