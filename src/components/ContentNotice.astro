---
export type NoticeKind = 'clinical' | 'psychological' | 'legal';

interface Props {
  kind?: NoticeKind;
}

const { kind = 'clinical' } = Astro.props;
const notices = {
  clinical: {
    title: 'Conteúdo clínico em preparação',
    body: 'Esta área está sendo construída com fontes rastreáveis e auditoria assistida por IA. As informações disponíveis agora são institucionais e não substituem uma consulta.',
  },
  psychological: {
    title: 'Conteúdo de acolhimento em preparação',
    body: 'Esta área está sendo construída com auditoria editorial e linguagem cuidadosa. O conteúdo disponível agora não substitui apoio psicológico profissional.',
  },
  legal: {
    title: 'Conteúdo jurídico em preparação',
    body: 'Esta área está sendo preparada com fontes oficiais e auditoria assistida por IA. As informações disponíveis agora são institucionais e não substituem orientação profissional sobre uma situação específica.',
  },
};
const notice = notices[kind];
---

<aside class:list={['notice', `notice-${kind}`]} aria-label="Aviso importante" data-notice-kind={kind}>
  <strong>{notice.title}</strong>
  <p>{notice.body}</p>
</aside>
