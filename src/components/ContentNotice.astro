---
export type NoticeKind = 'clinical' | 'psychological' | 'legal';

interface Props {
  kind?: NoticeKind;
}

const { kind = 'clinical' } = Astro.props;
const notices = {
  clinical: {
    title: 'Limites deste conteúdo',
    body: 'As informações desta página são educativas e não substituem uma consulta ou avaliação individual.',
  },
  psychological: {
    title: 'Limites deste conteúdo',
    body: 'Este espaço oferece informação e acolhimento, mas não substitui apoio psicológico ou atendimento de emergência.',
  },
  legal: {
    title: 'Limites deste conteúdo',
    body: 'As informações são gerais e não substituem orientação jurídica sobre uma situação específica.',
  },
};
const notice = notices[kind];
---

<aside class:list={['notice', `notice-${kind}`]} aria-label="Aviso importante" data-notice-kind={kind}>
  <strong>{notice.title}</strong>
  <p>{notice.body}</p>
</aside>
